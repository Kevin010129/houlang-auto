---
export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "zh" } },
  ];
}

import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const isZh = lang === "zh";

const benefits = [
  {
    icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6",
    text: isZh
      ? "30+ 中国新能源汽车品牌的工厂直采价格"
      : "Access to 30+ Chinese NEV brands at factory-direct pricing",
  },
  {
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    text: isZh
      ? "专属客户经理和优先支持服务"
      : "Dedicated account manager and priority support",
  },
  {
    icon: "M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z",
    text: isZh
      ? "营销物料和本地推广支持"
      : "Marketing materials and local promotion support",
  },
  {
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    text: isZh
      ? "有竞争力的利润空间和销量激励方案"
      : "Competitive margins and volume-based incentive programs",
  },
];

const title = isZh ? "加盟合作 — 常州后浪新能源汽车进出口有限公司" : "Join Our Network — Changzhou Houlang New Energy Vehicle Import & Export Co., Ltd.";
const description = isZh
  ? "成为常州后浪新能源汽车进出口有限公司全球合作伙伴，享受工厂直采价格和专属支持。"
  : "Become a Changzhou Houlang New Energy Vehicle Import & Export Co., Ltd. global partner and enjoy factory-direct pricing and dedicated support.";
---

<MainLayout {title} {description}>
  <section class="bg-primary text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold">{isZh ? "加盟合作" : "Join Our Network"}</h1>
      <p class="text-blue-200 mt-2">
        {isZh ? "成为您所在地区的常州后浪新能源汽车进出口有限公司授权合作伙伴" : "Become an authorized Changzhou Houlang New Energy Vehicle Import & Export Co., Ltd. partner in your region"}
      </p>
    </div>
  </section>

  <!-- Benefits -->
  <section class="section bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{isZh ? "合作伙伴权益" : "Partner Benefits"}</h2>
          <div class="space-y-4">
            {benefits.map((b, i) => (
              <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
                <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={b.icon}/>
                  </svg>
                </div>
                <p class="text-gray-700 text-sm leading-relaxed">{b.text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Application Form -->
        <div>
          <h2 class="text-2xl font-bold text-gray-900 mb-6">{isZh ? "申请成为合作伙伴" : "Apply for Partnership"}</h2>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="bg-gray-warm rounded-xl p-6 md:p-8"
          >
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
            <input type="hidden" name="subject" value={`New partnership application (${lang})`} />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                  {isZh ? "公司名称" : "Company Name"}
                </label>
                <input
                  type="text"
                  name="company"
                  required
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                  {isZh ? "您的姓名" : "Your Name"}
                </label>
                <input
                  type="text"
                  name="name"
                  required
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white"
                />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                  <input
                    type="email"
                    name="email"
                    required
                    class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white"
                  />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">
                    {isZh ? "电话" : "Phone"}
                  </label>
                  <input
                    type="text"
                    name="phone"
                    class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white"
                  />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                  {isZh ? "国家/地区" : "Country / Region"}
                </label>
                <input
                  type="text"
                  name="country"
                  required
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                  {isZh ? "留言" : "Message"}
                </label>
                <textarea
                  name="message"
                  rows="3"
                  class="w-full px-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white resize-none"
                  placeholder={isZh ? "请简要介绍您的公司和合作意向..." : "Briefly introduce your company and partnership interests..."}
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-3 rounded-lg transition-colors"
              >
                {isZh ? "提交申请" : "Submit Application"}
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
