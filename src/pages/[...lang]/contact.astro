---
export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "zh" } },
  ];
}

import MainLayout from "../../layouts/MainLayout.astro";
import { getLangFromUrl } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const isZh = lang === "zh";

const title = isZh ? "联系我们 — 后浪汽车" : "Contact Us — Houlang Auto";
const description = isZh
  ? "联系我们获取新能源汽车出口咨询和报价。我们将在24小时内回复。"
  : "Contact us for NEV export inquiries and quotations. We'll respond within 24 hours.";
---

<MainLayout {title} {description}>
  <section class="bg-primary text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold">{isZh ? "联系我们" : "Contact Us"}</h1>
      <p class="text-blue-200 mt-2">
        {isZh ? "我们期待与您的合作" : "We look forward to working with you"}
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-3 gap-16">
        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-6">{isZh ? "联系方式" : "Contact Info"}</h2>
            <div class="space-y-6">
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 text-sm">{isZh ? "地址" : "Address"}</h3>
                  <p class="text-gray-500 text-sm mt-1">{isZh ? "中国江苏省常州市" : "Changzhou, Jiangsu, China"}</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 text-sm">Email</h3>
                  <p class="text-gray-500 text-sm mt-1">info@houlangauto.com</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 text-sm">{isZh ? "电话" : "Phone"}</h3>
                  <p class="text-gray-500 text-sm mt-1">+86-XXX-XXXX-XXXX</p>
                </div>
              </div>
              <div class="flex gap-4">
                <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 text-sm">WhatsApp</h3>
                  <p class="text-gray-500 text-sm mt-1">+86-XXX-XXXX-XXXX</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2">
          <div class="bg-gray-warm rounded-2xl p-8">
            <h2 class="text-xl font-bold text-gray-900 mb-2">{isZh ? "发送留言" : "Send a Message"}</h2>
            <p class="text-gray-500 text-sm mb-6">{isZh ? "我们将在 24 小时内回复您。" : "We'll get back to you within 24 hours."}</p>
            <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
              <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
              <input type="hidden" name="subject" value={`Contact form submission from Houlang Auto (${lang})`} />
              <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">{isZh ? "您的姓名" : "Your Name"} *</label>
                  <input type="text" name="name" required class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">Email *</label>
                  <input type="email" name="email" required class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white" />
                </div>
              </div>
              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">{isZh ? "电话 / WhatsApp" : "Phone / WhatsApp"}</label>
                  <input type="text" name="phone" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1.5">{isZh ? "公司名称" : "Company Name"}</label>
                  <input type="text" name="company" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white" />
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">{isZh ? "感兴趣的车型" : "Vehicles of Interest"}</label>
                <input type="text" name="vehicles" class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white" placeholder={isZh ? "例如：BYD、蔚来、极氪..." : "e.g. BYD, NIO, Zeekr..."} />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1.5">{isZh ? "留言" : "Message"} *</label>
                <textarea name="message" rows="5" required class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary text-sm bg-white resize-none" placeholder={isZh ? "请描述您的需求..." : "Describe your requirements..."}></textarea>
              </div>
              <button type="submit" class="w-full bg-accent hover:bg-accent-hover text-white font-semibold py-3.5 rounded-lg transition-colors text-base">
                {isZh ? "发送消息" : "Send Message"}
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
