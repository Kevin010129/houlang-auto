---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems = [
  { key: "home", href: `/${lang}/` },
  { key: "products", href: `/${lang}/products/` },
  { key: "about", href: `/${lang}/about/` },
  { key: "service", href: `/${lang}/service/` },
  { key: "partner", href: `/${lang}/partner/` },
  { key: "cases", href: `/${lang}/cases/` },
  { key: "news", href: `/${lang}/news/` },
  { key: "contact", href: `/${lang}/contact/` },
];

const altLang = lang === "en" ? "zh" : "en";
const altPath = `/${altLang}${currentPath.replace(/^\/(en|zh)/, "") || "/"}`;

function isActive(href: string): boolean {
  if (href === `/${lang}/`) return currentPath === `/${lang}/`;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 glass shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-18">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-3 flex-shrink-0 group">
        <div class="w-10 h-10 bg-gradient-to-br from-primary to-primary-light rounded-xl flex items-center justify-center shadow-lg group-hover:scale-105 transition-transform">
          <span class="text-white font-bold text-sm">后</span>
        </div>
        <div class="hidden md:block">
          <p class="text-sm font-bold text-primary leading-tight">
            {lang === "zh" ? "常州后浪新能源汽车" : "Changzhou Houlang"}
          </p>
          <p class="text-xs text-gray-400 leading-tight">
            {lang === "zh" ? "进出口有限公司" : "NEV Import & Export"}
          </p>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`relative px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
              isActive(item.href)
                ? "text-accent bg-accent-light/30"
                : "text-gray-600 hover:text-primary hover:bg-gray-50 link-underline"
            }`}
          >
            {t(`nav.${item.key}`)}
          </a>
        ))}
      </nav>

      <!-- Language Switcher + Mobile Menu -->
      <div class="flex items-center gap-3">
        <a
          href={altPath}
          class="text-xs font-semibold text-gray-500 hover:text-primary transition-colors px-3 py-2 border-2 border-gray-200 rounded-lg hover:border-primary/30 hover:bg-primary/5 uppercase tracking-wide"
        >
          {lang === "en" ? "中文" : "EN"}
        </a>
        <button id="menu-toggle" class="lg:hidden p-2 text-gray-600 hover:text-primary transition-colors rounded-lg hover:bg-gray-100" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-gray-100 mt-2 pt-3">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-4 py-3 rounded-lg text-base font-medium transition-all ${
            isActive(item.href)
              ? "text-accent bg-accent-light/20"
              : "text-gray-600 hover:text-primary hover:bg-gray-50"
          }`}
        >
          {t(`nav.${item.key}`)}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  document.getElementById("menu-toggle")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
