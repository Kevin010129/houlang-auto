---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems = [
  { key: "home", href: `/${lang}/` },
  { key: "products", href: `/${lang}/products/` },
  { key: "about", href: `/${lang}/about/` },
  { key: "service", href: `/${lang}/service/` },
  { key: "partner", href: `/${lang}/partner/` },
  { key: "cases", href: `/${lang}/cases/` },
  { key: "news", href: `/${lang}/news/` },
  { key: "contact", href: `/${lang}/contact/` },
];

const altLang = lang === "en" ? "zh" : "en";
const altPath = `/${altLang}${currentPath.replace(/^\/(en|zh)/, "") || "/"}`;

function isActive(href: string): boolean {
  if (href === `/${lang}/`) return currentPath === `/${lang}/`;
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-2 flex-shrink-0">
        <span class="text-lg md:text-xl font-bold text-primary">
          {lang === "zh" ? "常州后浪新能源汽车进出口有限公司" : "Changzhou Houlang New Energy Vehicle Import & Export Co., Ltd."}
        </span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${
              isActive(item.href)
                ? "text-primary bg-blue-50"
                : "text-gray-600 hover:text-primary hover:bg-gray-50"
            }`}
          >
            {t(`nav.${item.key}`)}
          </a>
        ))}
      </nav>

      <!-- Language Switcher + Mobile Menu -->
      <div class="flex items-center gap-3">
        <a
          href={altPath}
          class="text-sm font-medium text-gray-500 hover:text-primary transition-colors px-3 py-1.5 border border-gray-200 rounded-md hover:border-primary"
        >
          {lang === "en" ? "中文" : "English"}
        </a>
        <button id="menu-toggle" class="lg:hidden p-2 text-gray-600 hover:text-primary" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden lg:hidden pb-4 border-t border-gray-100 mt-2 pt-2">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`block px-3 py-2 rounded-md text-base font-medium ${
            isActive(item.href)
              ? "text-primary bg-blue-50"
              : "text-gray-600 hover:text-primary hover:bg-gray-50"
          }`}
        >
          {t(`nav.${item.key}`)}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  document.getElementById("menu-toggle")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });
</script>
