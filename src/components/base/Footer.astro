---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const brandLinks = [
  { name: "BYD", href: `/${lang}/brands/byd/` },
  { name: "NIO", href: `/${lang}/brands/nio/` },
  { name: "Xiaomi", href: `/${lang}/brands/xiaomi/` },
  { name: "Li Auto", href: `/${lang}/brands/li-auto/` },
  { name: "Zeekr", href: `/${lang}/brands/zeekr/` },
  { name: "XPeng", href: `/${lang}/brands/xpeng/` },
];

const typeLinks = [
  { key: "mini", href: `/${lang}/products/?type=MINI` },
  { key: "sedan", href: `/${lang}/products/?type=SEDAN` },
  { key: "suv", href: `/${lang}/products/?type=SUV` },
  { key: "mpv", href: `/${lang}/products/?type=MPV` },
];

const fuelLinks = [
  { key: "electric", href: `/${lang}/products/?fuel=electric` },
  { key: "phev", href: `/${lang}/products/?fuel=plug_in_hybrid` },
  { key: "erev", href: `/${lang}/products/?fuel=extended_range` },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-8">
      <!-- Brand & Social -->
      <div class="col-span-2 md:col-span-1">
        <span class="text-lg font-bold text-white">{lang === "zh" ? "常州后浪新能源汽车进出口有限公司" : "Changzhou Houlang New Energy Vehicle Import & Export Co., Ltd."}</span>
        <p class="text-xs text-gray-500 mt-4 leading-relaxed">{t("about.mission_text")}</p>
      </div>

      <!-- Brands -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t("footer.brands")}</h4>
        <ul class="space-y-2">
          {brandLinks.map((b) => (
            <li><a href={b.href} class="text-sm text-gray-400 hover:text-white transition-colors">{b.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Types -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t("footer.types")}</h4>
        <ul class="space-y-2">
          {typeLinks.map((item) => (
            <li><a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">{t(`filter.${item.key}`)}</a></li>
          ))}
        </ul>
        <h4 class="text-white font-semibold text-sm mt-6 mb-4">{t("footer.fuel")}</h4>
        <ul class="space-y-2">
          {fuelLinks.map((item) => (
            <li><a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors">{t(`filter.${item.key}`)}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t("footer.quickLinks")}</h4>
        <ul class="space-y-2">
          <li><a href={`/${lang}/about/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.about")}</a></li>
          <li><a href={`/${lang}/products/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.products")}</a></li>
          <li><a href={`/${lang}/partner/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.partner")}</a></li>
          <li><a href={`/${lang}/service/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.service")}</a></li>
          <li><a href={`/${lang}/cases/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.cases")}</a></li>
          <li><a href={`/${lang}/news/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.news")}</a></li>
          <li><a href={`/${lang}/contact/`} class="text-sm text-gray-400 hover:text-white transition-colors">{t("nav.contact")}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">{t("footer.contact")}</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>{t("contact.email_address")}</li>
          <li>{t("contact.phone_number")}</li>
          <li class="mt-2">{t("contact.address")}</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-12 pt-8 text-center text-sm text-gray-500">
      <p>{t("footer.copyright")}</p>
    </div>
  </div>
</footer>
