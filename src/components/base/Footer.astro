---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const brandLinks = [
  { name: "BYD", href: `/${lang}/brands/byd/` },
  { name: "NIO", href: `/${lang}/brands/nio/` },
  { name: "Xiaomi", href: `/${lang}/brands/xiaomi/` },
  { name: "Li Auto", href: `/${lang}/brands/li-auto/` },
  { name: "Zeekr", href: `/${lang}/brands/zeekr/` },
  { name: "XPeng", href: `/${lang}/brands/xpeng/` },
];

const typeLinks = [
  { key: "mini", href: `/${lang}/products/?type=MINI` },
  { key: "sedan", href: `/${lang}/products/?type=SEDAN` },
  { key: "suv", href: `/${lang}/products/?type=SUV` },
  { key: "mpv", href: `/${lang}/products/?type=MPV` },
];

const fuelLinks = [
  { key: "electric", href: `/${lang}/products/?fuel=electric` },
  { key: "phev", href: `/${lang}/products/?fuel=plug_in_hybrid` },
  { key: "erev", href: `/${lang}/products/?fuel=extended_range` },
];
---

<footer class="bg-gradient-to-br from-gray-900 via-slate-900 to-gray-950 text-gray-300 relative overflow-hidden">
  <div class="absolute top-0 left-1/2 w-[600px] h-[600px] bg-primary/20 rounded-full blur-[200px] -translate-x-1/2 -translate-y-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-10">
      <!-- Brand & Social -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-accent to-accent-hover rounded-xl flex items-center justify-center shadow-lg">
            <span class="text-white font-bold text-sm">后</span>
          </div>
          <span class="text-lg font-bold text-white">{lang === "zh" ? "后浪汽车" : "HOULANG"}</span>
        </div>
        <p class="text-xs text-gray-500 leading-relaxed mt-3">{t("about.mission_text")}</p>
      </div>

      <!-- Brands -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-5">{t("footer.brands")}</h4>
        <ul class="space-y-2.5">
          {brandLinks.map((b) => (
            <li><a href={b.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{b.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Types -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-5">{t("footer.types")}</h4>
        <ul class="space-y-2.5">
          {typeLinks.map((item) => (
            <li><a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t(`filter.${item.key}`)}</a></li>
          ))}
        </ul>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mt-8 mb-5">{t("footer.fuel")}</h4>
        <ul class="space-y-2.5">
          {fuelLinks.map((item) => (
            <li><a href={item.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t(`filter.${item.key}`)}</a></li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-5">{t("footer.quickLinks")}</h4>
        <ul class="space-y-2.5">
          <li><a href={`/${lang}/about/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.about")}</a></li>
          <li><a href={`/${lang}/products/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.products")}</a></li>
          <li><a href={`/${lang}/partner/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.partner")}</a></li>
          <li><a href={`/${lang}/service/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.service")}</a></li>
          <li><a href={`/${lang}/cases/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.cases")}</a></li>
          <li><a href={`/${lang}/news/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.news")}</a></li>
          <li><a href={`/${lang}/contact/`} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">{t("nav.contact")}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white font-bold text-xs uppercase tracking-widest mb-5">{t("footer.contact")}</h4>
        <ul class="space-y-3 text-sm text-gray-400">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {t("contact.email_address")}
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {t("contact.phone_number")}
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-gray-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            {t("contact.address")}
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/5 mt-16 pt-8 text-center text-xs text-gray-600">
      <p>{t("footer.copyright")}</p>
    </div>
  </div>
</footer>
