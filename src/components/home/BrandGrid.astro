---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { getCollection } from "astro:content";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const brands = await getCollection("brands");
const featuredBrands = brands
  .filter((b) => b.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="section bg-gray-warm relative overflow-hidden">
  <!-- Background decoration -->
  <div class="absolute top-0 right-0 w-72 h-72 bg-accent/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="section-heading">{t("home.browseByBrand")}</h2>
    <p class="section-subheading">
      {lang === "zh"
        ? "覆盖中国主流新能源汽车品牌，一站式采购"
        : "Covering all major Chinese NEV brands for one-stop sourcing"}
    </p>
    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-4 md:gap-6">
      {featuredBrands.map((brand) => (
        <a
          href={`/${lang}/brands/${brand.data.slug}/`}
          class="card-hover group flex flex-col items-center justify-center gap-3 p-6 bg-white rounded-2xl border border-gray-100/80"
        >
          <div class="w-16 h-16 bg-gradient-to-br from-gray-50 to-gray-100 rounded-2xl flex items-center justify-center group-hover:from-primary/10 group-hover:to-primary/5 transition-all duration-300 shadow-sm group-hover:shadow-md">
            <span class="text-lg font-extrabold text-primary group-hover:scale-110 transition-transform">
              {brand.data.names[lang as keyof typeof brand.data.names] || brand.data.names.en}
            </span>
          </div>
          <span class="text-xs text-gray-600 text-center font-semibold group-hover:text-primary transition-colors">
            {brand.data.names[lang as keyof typeof brand.data.names] || brand.data.names.en}
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
