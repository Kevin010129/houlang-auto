---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);
---

<section class="relative bg-gradient-to-br from-primary via-slate-900 to-primary-dark text-white overflow-hidden">
  <!-- Animated background elements -->
  <div class="absolute inset-0">
    <div class="absolute top-20 right-10 w-96 h-96 bg-accent/20 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-0 left-10 w-80 h-80 bg-blue-500/20 rounded-full blur-[100px]"></div>
    <div class="absolute top-1/3 right-1/3 w-64 h-64 bg-gold/10 rounded-full blur-[80px]"></div>
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 md:py-40">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full border border-white/10 mb-8">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        <span class="text-sm text-blue-100">
          {lang === "zh" ? "30+ 品牌 · 200+ 车型 · 全球出口" : "30+ Brands · 200+ Models · Global Export"}
        </span>
      </div>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold leading-tight mb-6 tracking-tight">
        {lang === "zh" ? "中国新能源汽车" : "Your Trusted Partner"}
        <br/>
        <span class="gradient-text">
          {lang === "zh" ? "出口值得信赖的伙伴" : "for Chinese NEV Export"}
        </span>
      </h1>
      <p class="text-lg md:text-xl text-blue-100/80 mb-4 max-w-xl leading-relaxed">
        {t("home.heroSubtitle")}
      </p>
      <p class="text-base text-blue-200/60 mb-10">
        {t("home.heroTagline")}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={`/${lang}/products/`} class="btn-primary text-lg px-8 py-4">
          {t("home.heroCta")}
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a href={`/${lang}/about/`} class="btn-outline text-lg px-8 py-4">
          {t("nav.about")}
        </a>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-20">
      {[
        { num: "30+", label: lang === "zh" ? "合作品牌" : "Brand Partners", icon: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" },
        { num: "200+", label: lang === "zh" ? "出口车型" : "Vehicle Models", icon: "M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1" },
        { num: "50+", label: lang === "zh" ? "出口国家" : "Countries", icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { num: "1000+", label: lang === "zh" ? "满意客户" : "Happy Clients", icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
      ].map((stat) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 border border-white/10 hover:bg-white/10 transition-all duration-300 group">
          <svg class="w-6 h-6 text-accent/60 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={stat.icon}/>
          </svg>
          <div class="text-3xl md:text-4xl font-bold text-white group-hover:scale-105 transition-transform">{stat.num}</div>
          <div class="text-blue-200/60 text-sm mt-1">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" class="w-full"><path fill="white" d="M0 80L48 66.7C96 53 192 27 288 20C384 13 480 27 576 33.3C672 40 768 40 864 33.3C960 27 1056 13 1152 13.3C1248 13 1344 27 1392 33.3L1440 40V80H0z"/></svg>
  </div>
</section>
