---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const newsItems = [
  {
    title: { en: "Xiaomi SU7 Ultra — Production Version Real Shots Revealed", zh: "小米 SU7 Ultra 量产版实拍图曝光" },
    date: "2025-05-20",
    slug: "xiaomi-su7-ultra-production",
  },
  {
    title: { en: "Zeekr MIX Officially Launched", zh: "极氪 MIX 正式上市" },
    date: "2025-05-15",
    slug: "zeekr-mix-launched",
  },
  {
    title: { en: "Chery iCAR V23 Starts Pre-sale", zh: "奇瑞 iCAR V23 开启预售" },
    date: "2025-05-10",
    slug: "chery-icar-v23-presale",
  },
  {
    title: { en: "BYD Seal 06GT Officially Launched", zh: "比亚迪海豹 06GT 正式上市" },
    date: "2025-05-05",
    slug: "byd-seal-06gt-launched",
  },
];
---

<section class="section bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h2 class="section-heading text-left">{t("home.latestNews")}</h2>
        <p class="text-gray-500 mt-2">
          {lang === "zh" ? "关注中国新能源汽车行业最新动态" : "Stay updated with China's NEV industry"}
        </p>
      </div>
      <a
        href={`/${lang}/news/`}
        class="text-primary hover:text-primary-light font-medium text-sm flex items-center gap-1 transition-colors"
      >
        {t("home.viewAll")}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {newsItems.map((item) => (
        <a href={`/${lang}/news/${item.slug}/`} class="group">
          <div class="aspect-[16/9] bg-gray-100 rounded-lg mb-3 overflow-hidden">
            <div class="w-full h-full bg-gray-200 flex items-center justify-center text-gray-400 text-sm">
              {lang === "zh" ? "新闻图片" : "News Image"}
            </div>
          </div>
          <p class="text-xs text-gray-400 mb-1">{item.date}</p>
          <h3 class="text-sm font-semibold text-gray-900 group-hover:text-primary transition-colors line-clamp-2">
            {item.title[lang as keyof typeof item.title] || item.title.en}
          </h3>
        </a>
      ))}
    </div>
  </div>
</section>
