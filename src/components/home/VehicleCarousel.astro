---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";
import { getCollection } from "astro:content";

interface Props {
  vehicleType: "SEDAN" | "SUV" | "MPV" | "MINI";
}

const { vehicleType } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const vehicles = await getCollection("vehicles");
const brands = await getCollection("brands");
const brandMap = new Map(brands.map((b) => [b.id, b.data]));

const filtered = vehicles
  .filter((v) => v.data.type === vehicleType && v.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const typeKey = vehicleType.toLowerCase();
const typeLabel = t(`filter.${typeKey}`);
---

<section class="section bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900">{typeLabel}</h2>
      <a
        href={`/${lang}/products/?type=${vehicleType}`}
        class="text-primary hover:text-primary-light font-medium text-sm flex items-center gap-1 transition-colors"
      >
        {t("home.viewAll")}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {filtered.map((vehicle) => {
        const v = vehicle.data;
        const bd = brandMap.get(v.brand);
        const name = lang === "zh" ? v.names.zh : v.names.en;
        const brandName = lang === "zh" ? (bd?.names.zh ?? v.brand) : (bd?.names.en ?? v.brand);
        return (
          <a
            href={`/${lang}/products/${v.slug}/`}
            class="group bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-lg hover:border-gray-200 transition-all"
          >
            <div class="aspect-[4/3] bg-gray-100 flex items-center justify-center overflow-hidden">
              {v.images[0] ? (
                <img
                  src={v.images[0]}
                  alt={name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              ) : (
                <div class="text-gray-400 text-sm">{lang === "zh" ? "图片加载中" : "Image"}</div>
              )}
            </div>
            <div class="p-4">
              <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">{brandName}</p>
              <h3 class="text-sm font-semibold text-gray-900 mt-1 group-hover:text-primary transition-colors">{name}</h3>
              <p class="text-xs text-accent font-medium mt-2">
                ¥{v.priceRange.min.toLocaleString()} - ¥{v.priceRange.max.toLocaleString()}
              </p>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
