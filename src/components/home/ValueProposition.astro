---
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { t } = useTranslations(lang);

const features = [
  { key: "pricing", color: "bg-emerald-500", bgLight: "bg-emerald-50", textColor: "text-emerald-600" },
  { key: "logistics", color: "bg-blue-500", bgLight: "bg-blue-50", textColor: "text-blue-600" },
  { key: "quality", color: "bg-violet-500", bgLight: "bg-violet-50", textColor: "text-violet-600" },
  { key: "support", color: "bg-amber-500", bgLight: "bg-amber-50", textColor: "text-amber-600" },
];
---

<section class="section bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="section-heading">{t("why.title")}</h2>
    <p class="section-subheading">
      {lang === "zh"
        ? "以专业和用心赢得信赖"
        : "Earning your trust through professionalism and care"}
    </p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 mt-8">
      {features.map((f) => (
        <div class="group p-8 rounded-2xl border border-gray-100 hover:border-transparent hover:shadow-xl transition-all duration-300 relative overflow-hidden">
          <div class={`absolute top-0 right-0 w-24 h-24 ${f.bgLight} rounded-bl-[80px] -translate-y-4 translate-x-4 group-hover:scale-150 transition-transform duration-500`}></div>
          <div class={`relative w-14 h-14 ${f.bgLight} rounded-xl flex items-center justify-center mb-5 group-hover:scale-110 transition-transform`}>
            <div class={`w-3 h-3 rounded-full ${f.color}`}></div>
          </div>
          <h3 class={`text-lg font-bold text-gray-900 mb-3 group-hover:${f.textColor} transition-colors`}>{t(`why.${f.key}.title`)}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{t(`why.${f.key}.desc`)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
